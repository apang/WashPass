import { v4 as uuidv4 } from 'uuid';

@Injectable()
export class RedemptionService {
  constructor(private readonly redis: RedisService) {}

  async issueCode(userId: string, stationId: string) {
    const redis = this.redis.getClient();

    // Rate limit
    const rateKey = `redeem:rate:${userId}`;
    const attempts = await redis.incr(rateKey);
    if (attempts === 1) {
      await redis.expire(rateKey, 60);
    }

    if (attempts > 5) {
      throw new ConflictException('Rate limit exceeded');
    }

    // Lock issuance
    const lockKey = `redeem:lock:${userId}`;
    const lock = await redis.set(lockKey, '1', 'NX', 'EX', 5);

    if (!lock) {
      throw new ConflictException('Redemption already in progress');
    }

    const code = uuidv4().slice(0, 8).toUpperCase();

    await redis.set(
      `redeem:code:${code}`,
      JSON.stringify({
        userId,
        stationId,
        createdAt: Date.now(),
      }),
      'EX',
      600,
    );

    return { code };
  }
