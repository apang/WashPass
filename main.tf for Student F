4️⃣ Backend Enforcement (NestJS)

This is critical.

Never trust frontend validation.

4.1 Create GeoGuard Middleware
@Injectable()
export class GeoGuard implements CanActivate {

  async canActivate(context: ExecutionContext): Promise<boolean> {

    const ctx = GqlExecutionContext.create(context);
    const req = ctx.getContext().req;

    const lat = parseFloat(req.headers['x-washpass-lat']);
    const lng = parseFloat(req.headers['x-washpass-lng']);
    const timestamp = parseInt(req.headers['x-washpass-timestamp']);

    if (!lat || !lng || !timestamp) {
      throw new ForbiddenException('Location verification required');
    }

    const now = Date.now();
    if (now - timestamp > 60000) {
      throw new ForbiddenException('Location timestamp expired');
    }

    const location = await this.locationService.getLocationById(
      ctx.getArgs().locationId
    );

    const distance = this.geoService.getDistanceMeters(
      lat,
      lng,
      location.latitude,
      location.longitude
    );

    if (distance > 200) {
      throw new ForbiddenException('Not within authorized proximity');
    }

    return true;
  }
}

Apply to:

generateRedemptionCode mutation
